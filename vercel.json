{
  "framework": "vite",
  "buildCommand": "npm run web:build",
  "outputDirectory": "apps/boardcad-desktop/dist",
  "installCommand": "npm ci",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
