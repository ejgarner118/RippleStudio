{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DATA/**" },
        { "path": "$PICTURE/**" },
        { "path": "$PUBLIC/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$TEMP/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$CONFIG/**" },
        { "path": "$CACHE/**" }
      ]
    }
  ]
}
